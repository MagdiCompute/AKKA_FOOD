# ============================================================================
# Orange Money API Secrets — Reference File
# ============================================================================
#
# These secrets are managed via Firebase Secret Manager, NOT .env files.
# This file exists only as a developer reference showing required secret names.
#
# DO NOT create a .env file with real values. Use Firebase CLI instead:
#   firebase functions:secrets:set SECRET_NAME
#
# See SECRETS.md for full setup instructions.
# ============================================================================

# API key for authenticating with Orange Money Mali API
ORANGE_MONEY_API_KEY=

# Base URL for the Orange Money API (e.g., https://api.orange-money.com/v1)
ORANGE_MONEY_BASE_URL=

# Public HTTPS callback URL that Orange Money calls on payment status change
ORANGE_MONEY_CALLBACK_URL=

# HMAC-SHA256 shared secret for validating callback signatures
ORANGE_MONEY_CALLBACK_SECRET=
