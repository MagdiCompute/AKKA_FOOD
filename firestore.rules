rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper functions
    // -------------------------------------------------------------------------

    /// Returns true when the requesting user is authenticated.
    function isAuthenticated() {
      return request.auth != null;
    }

    /// Returns true when the requesting user owns the document (uid matches).
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    /// Returns true when the requesting user has the 'admin' role.
    /// Role is stored in /users/{uid}.role and is verified server-side by
    /// reading the caller's own user document.
    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // -------------------------------------------------------------------------
    // /meals/{mealId}
    //
    // Task 8.1 — /meals writable only by admin role.
    // Task 7.2 (recommendation-system) — popularityScore protection.
    //
    // Any authenticated user may read meals (catalog browsing).
    // Admin may create/update/delete meals via client SDK, but the
    // `popularityScore` field is protected:
    //   • On create: must be 0 (Cloud Functions will increment it later)
    //   • On update: must remain unchanged (only Cloud Functions using the
    //     Admin SDK — which bypasses Security Rules — can increment it)
    //
    // This ensures popularity scores are exclusively managed by the
    // `onOrderCompletedRecommendations` Cloud Function trigger.
    // -------------------------------------------------------------------------
    match /meals/{mealId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() &&
        request.resource.data.popularityScore == 0;
      allow update: if isAdmin() &&
        request.resource.data.popularityScore == resource.data.popularityScore;
      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // /categories/{categoryId}
    //
    // Task 8.1 — /categories writable only by admin role.
    // Any authenticated user may read categories.
    // -------------------------------------------------------------------------
    match /categories/{categoryId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // /orders/{orderId}
    //
    // Task 7.2 (payment-processing spec) — Order security rules.
    //
    // Access model:
    //   • Read: An authenticated user whose uid matches the order's uid field
    //     may read the document (order history, confirmation). Admins may read
    //     any order (dashboard / support use).
    //   • Write: All client writes are denied. Orders are created exclusively
    //     by Cloud Functions (Admin SDK) after successful payment confirmation
    //     in the orangeMoneyCallback function. The Admin SDK bypasses Security
    //     Rules entirely.
    //
    // Satisfies Requirement 2.2: Order created by Order_Service (Cloud Function)
    // upon payment-success event.
    // -------------------------------------------------------------------------
    match /orders/{orderId} {
      allow read: if isAuthenticated() &&
        (request.auth.uid == resource.data.uid || isAdmin());
      allow write: if false; // Only Cloud Functions (Admin SDK) can write
    }

    // -------------------------------------------------------------------------
    // /transactions/{transactionId}
    //
    // Task 7.1 (payment-processing spec) — Transaction security rules.
    //
    // Access model:
    //   • Read: Only the authenticated user whose uid matches the transaction's
    //     uid field may read the document (payment history, real-time status).
    //   • Write: All client writes are denied. Transaction documents are created
    //     and updated exclusively by Cloud Functions using the Admin SDK (which
    //     bypasses Security Rules entirely).
    //
    // Satisfies Requirement 6: Security and Compliance — payment data handled
    // securely; users can only read their own transactions.
    // -------------------------------------------------------------------------
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.uid;
      allow write: if false; // Only Cloud Functions (Admin SDK) can write

      // ---------------------------------------------------------------------
      // /transactions/{transactionId}/cartSnapshot/{doc}
      //
      // Cart snapshot subcollection — stores the cart state at payment
      // initiation time. Same access model as the parent transaction.
      // ---------------------------------------------------------------------
      match /cartSnapshot/{doc} {
        allow read: if isAuthenticated() &&
          request.auth.uid == get(/databases/$(database)/documents/transactions/$(transactionId)).data.uid;
        allow write: if false; // Only Cloud Functions (Admin SDK) can write
      }
    }

    // -------------------------------------------------------------------------
    // /users/{uid}
    //
    // Task 8.3 / Task 9.2 — /users readable by admin role (limited fields).
    //
    // Access model:
    //   • Owner (request.auth.uid == uid): may read and update their own doc.
    //   • Owner: may create their own doc during registration.
    //   • Admin: may read any user document (dashboard use).
    //   • Non-owners / unauthenticated: all access denied.
    //
    // SECURITY NOTE — server-only fields:
    //   `failedLoginAttempts` and `lockedUntil` are written exclusively by
    //   Cloud Functions using the Admin SDK (which bypasses Security Rules).
    //   Client SDKs must NOT write these fields directly. The rules below do
    //   not enforce field-level restrictions (Firestore rules cannot easily
    //   block individual fields on update), so the Cloud Function path is the
    //   authoritative guard. The app layer must never send these fields in
    //   client-side update calls.
    //
    //   Admin writes (deactivate/reactivate) also go through Cloud Functions
    //   to enforce the server-side path; direct client writes by admins are
    //   blocked here as a defence-in-depth measure.
    // -------------------------------------------------------------------------
    match /users/{uid} {
      // Owner: read and update their own document.
      // Satisfies Requirement 11.2: only the matching uid may access the doc.
      allow read, update: if isOwner(uid);

      // Allow user document creation during registration (owner creates own doc).
      allow create: if isOwner(uid);

      // Admin: read any user document (dashboard).
      // Field-level sensitivity (failedLoginAttempts, lockedUntil) is enforced
      // by the app layer; tokens are never written to Firestore by the client.
      allow read: if isAdmin();

      // Admin writes go through Cloud Functions only — block direct client writes.
      // allow update: if isAdmin();  // intentionally omitted — use CF path

      // -----------------------------------------------------------------------
      // /users/{uid}/addresses/{addressId}
      //
      // Task 8.1 (user-profile spec) — User profile subcollections.
      // Owner may read and write their own addresses.
      // -----------------------------------------------------------------------
      match /addresses/{addressId} {
        allow read, write: if isOwner(uid);
      }

      // -----------------------------------------------------------------------
      // /users/{uid}/notificationPrefs
      //
      // Task 8.1 (user-profile spec) — Notification preferences.
      // Owner may read and write their own notification preferences.
      // -----------------------------------------------------------------------
      match /notificationPrefs {
        allow read, write: if isOwner(uid);
      }

      // -----------------------------------------------------------------------
      // /users/{uid}/coinTransactions/{txId}
      //
      // Task 8.1 (user-profile spec) — Coin transaction history.
      // Owner may read their own coin transactions.
      // Coin transactions are written by Cloud Functions (server SDK bypasses
      // rules), so client writes are blocked.
      // -----------------------------------------------------------------------
      match /coinTransactions/{txId} {
        allow read: if isOwner(uid);
        allow write: if false; // Written only by Cloud Functions (server SDK)
      }
    }

    // -------------------------------------------------------------------------
    // /analytics/{document}
    //
    // Task 8.4 — /analytics readable by admin role.
    // Written exclusively by the aggregateAnalytics Cloud Function (server SDK
    // bypasses Security Rules), so no client write rule is needed.
    // -------------------------------------------------------------------------
    match /analytics/{document} {
      allow read: if isAdmin();
      allow write: if false; // Written only by Cloud Functions (server SDK)
    }

    // -------------------------------------------------------------------------
    // /analytics/{document}/{subcollection}/{subDoc}
    // Covers any sub-collections under /analytics (e.g. daily breakdowns).
    // -------------------------------------------------------------------------
    match /analytics/{document}/{subcollection}/{subDoc} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // -------------------------------------------------------------------------
    // /otp_rate_limits/{id}
    //
    // Task 9.3 — OTP rate limiting records.
    // Written exclusively by Cloud Functions (server SDK bypasses rules).
    // No client reads or writes are permitted.
    //
    // Satisfies Requirement 11.5: rate-limit OTP delivery to max 5 requests
    // per phone number or email address per hour.
    // -------------------------------------------------------------------------
    match /otp_rate_limits/{id} {
      allow read, write: if false; // Written only by Cloud Functions (server SDK)
    }

  }
}
